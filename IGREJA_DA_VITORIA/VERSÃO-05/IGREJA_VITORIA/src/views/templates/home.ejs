<!DOCTYPE html>
<html lang="pt-BR">
<%- include("../partials/head", { title: "Igreja da Vitória - Jaraguá-GO" }) %>

    <body>
        <%- include("../partials/header") %>

            <section id="inicio" class="hero" aria-labelledby="titulo-hero">
                <div class="hero-inner">
                    <div>
                        <h1 id="titulo-hero">
                            <%= hero.titulo %>
                        </h1>
                        <p>
                            <%= hero.descricao %>
                        </p>
                        <div class="hero-buttons">
                            <a href="#cultos" class="btn">
                                <i class="far fa-calendar-alt" aria-hidden="true"></i>
                                Participe de um culto
                            </a>
                            <a href="<%= contato.whatsapp %>?text=Gra%C3%A7a%20e%20paz!%20Quero%20uma%20informa%C3%A7%C3%A3o%20da%20Igreja%20da%20Vit%C3%B3ria."
                                class="btn" target="_blank" rel="noopener">
                                <i class="fab fa-whatsapp" aria-hidden="true"></i>
                                WhatsApp
                            </a>
                        </div>
                    </div>

                    <div class="hero-card">
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <img src="/img/logotopo.png" alt="Logo Igreja da Vitória" class="hero-banner" />
                            <h3 style="margin: 0;">Próximo culto</h3>
                        </div>
                        <p>Domingo, 19:00 — Culto da Vitória.</p>
                        <div class="hero-highlight">
                            <span>
                                <%= hero.endereco %>
                            </span>
                            <span>Pr. Presidente: <a href="<%= contato.instagramPastor %>" target="_blank"
                                    rel="noopener">@prdaniel10</a></span>
                        </div>
                    </div>
                </div>
            </section>

            <main>
                <% if (sucesso==="pedido-oracao-enviado" ) { %>
                    <section class="feedback-ok" aria-live="polite">
                        Pedido de oração enviado com sucesso.
                    </section>
                    <% } %>

                        <% if (sucesso==="contato-enviado" ) { %>
                            <section class="feedback-ok" aria-live="polite">
                                Mensagem enviada com sucesso.
                            </section>
                            <% } %>

                                <section id="sobre">
                                    <h2>Sobre a Igreja da Vitória</h2>
                                    <p class="section-subtitle">
                                        Uma igreja que vive e prega a vitória em Cristo.
                                    </p>

                                    <div class="about-grid">
                                        <div>
                                            <p>
                                                A Igreja da Vitória em Jaraguá-GO existe para anunciar o evangelho de
                                                Jesus Cristo,
                                                cuidar de vidas e ver famílias restauradas pelo poder de Deus. Cremos em
                                                milagres,
                                                cura, libertação e em uma vida de vitória para aqueles que confiam no
                                                Senhor.
                                            </p>
                                            <div class="pill-list">
                                                <span class="pill">Vitória em Cristo</span>
                                                <span class="pill">Família</span>
                                                <span class="pill">Oração</span>
                                                <span class="pill">Milagres</span>
                                            </div>
                                        </div>

                                        <div class="card">
                                            <h3>Liderança</h3>
                                            <p><strong>Pastor Presidente:</strong> Pr. Daniel</p>
                                            <p>Siga no Instagram: <a href="<%= contato.instagramPastor %>"
                                                    target="_blank" rel="noopener">@prdaniel10</a></p>
                                            <br />
                                            <h3>Missão, visão e valores</h3>
                                            <p><strong>Missão:</strong> Levar pessoas a uma vida de vitória em Cristo.
                                            </p>
                                            <p><strong>Visão:</strong> Ser uma igreja que alcança e discipula multidões.
                                            </p>
                                            <p><strong>Valores:</strong> Fé, santidade, amor, serviço e unidade.</p>
                                        </div>
                                    </div>
                                </section>

                                <section id="cultos">
                                    <h2>Horários de cultos</h2>
                                    <p class="section-subtitle">
                                        Escolha um dos nossos cultos e venha adorar a Deus conosco.
                                    </p>

                                    <div class="schedule-grid">
                                        <% cultos.forEach(function(culto) { %>
                                            <article class="card schedule-item">
                                                <h3>
                                                    <%= culto.titulo %>
                                                </h3>
                                                <p><strong>
                                                        <%= culto.diaSemana %>
                                                    </strong>, <%= culto.horario %>
                                                </p>
                                                <p>
                                                    <%= culto.descricao %>
                                                </p>
                                            </article>
                                            <% }) %>
                                    </div>

                                    <div class="address-box">
                                        <p><strong>Endereço:</strong>
                                            <%= hero.endereco %>.
                                        </p>
                                    </div>
                                </section>

                                <section id="calendario">
                                    <h2>Calendário de eventos</h2>
                                    <p class="section-subtitle">
                                        Acompanhe os eventos da Igreja da Vitória pelo nosso calendário.
                                    </p>

                                    <div class="card card-spaced">
                                        <ul class="event-list">
                                            <% eventos.forEach(function(evento) { %>
                                                <li><strong>
                                                        <%= evento.data %> – <%= evento.horario %>:
                                                    </strong>
                                                    <%= evento.titulo %>
                                                        — <%= evento.descricao %>
                                                </li>
                                                <% }) %>
                                        </ul>
                                    </div>

                                    <div class="card">
                                        <iframe
                                            src="https://calendar.google.com/calendar/embed?src=SEU_CALENDARIO_AQUI&ctz=America%2FSao_Paulo"
                                            title="Calendário da Igreja da Vitória" class="calendar-embed"
                                            frameborder="0" scrolling="no">
                                        </iframe>
                                    </div>
                                </section>

                                <section id="ministerios">
                                    <h2>Ministérios</h2>
                                    <p class="section-subtitle">
                                        Ministérios que servem a Deus e abençoam vidas na Igreja da Vitória.
                                    </p>
                                    <div class="ministries-grid">
                                        <% ministerios.forEach(function(ministerio) { %>
                                            <article class="card">
                                                <h3>
                                                    <%= ministerio.nome %>
                                                </h3>
                                                <p>
                                                    <%= ministerio.descricao %>
                                                </p>
                                            </article>
                                            <% }) %>
                                    </div>
                                </section>

                                <section id="doacoes">
                                    <h2>Ofertas e doações</h2>
                                    <p class="section-subtitle">
                                        Se Deus tocar no seu coração para contribuir com a obra na Igreja da Vitória,
                                        veja
                                        abaixo as formas de ofertar.
                                    </p>

                                    <div class="card">
                                        <h3>PIX</h3>
                                        <p><strong>Chave PIX:</strong> COLOQUE_AQUI_SUA_CHAVE</p>
                                        <p><strong>Nome:</strong> Igreja da Vitória de Jaraguá</p>
                                    </div>

                                    <div class="card card-top-gap">
                                        <h3>Doar online</h3>
                                        <p>Clique no botão abaixo para ofertar (link da plataforma de doações da
                                            igreja).</p>
                                        <button class="btn" type="button">
                                            <i class="fas fa-heart" aria-hidden="true"></i>
                                            Ofertar agora
                                        </button>
                                    </div>

                                    <div class="card card-top-gap">
                                        <h3>Doar com cartão</h3>
                                        <p>Clique no botão abaixo para doar com cartão.</p>
                                        <button class="btn" type="button">
                                            <i class="fas fa-credit-card" aria-hidden="true"></i>
                                            Doar com cartão
                                        </button>
                                    </div>
                                </section>

                                <section id="oracao">
                                    <h2>Pedidos de oração</h2>
                                    <p class="section-subtitle">
                                        Envie seu pedido de oração. Ele será compartilhado com a equipe de intercessão
                                        da Igreja
                                        da Vitória.
                                    </p>

                                    <div class="contact-wrapper">
                                        <div class="card">
                                            <form action="/pedidos-oracao" method="POST" novalidate>
                                                <label for="nome_oracao">Nome</label>
                                                <input id="nome_oracao" name="nome" type="text"
                                                    placeholder="Seu nome completo" required aria-required="true" />

                                                <label for="cidade_oracao">Cidade / Estado</label>
                                                <input id="cidade_oracao" name="cidadeEstado" type="text"
                                                    placeholder="Ex: Jaraguá - GO" required aria-required="true" />

                                                <label for="categoria_oracao">Área do pedido</label>
                                                <input id="categoria_oracao" name="categoria" type="text"
                                                    placeholder="Família, saúde, finanças, ministério..." required
                                                    aria-required="true" />

                                                <label for="motivo_oracao">Motivo do pedido</label>
                                                <textarea id="motivo_oracao" name="motivo"
                                                    placeholder="Descreva seu pedido de oração com detalhes" required
                                                    aria-required="true"></textarea>

                                                <label class="consent-label" for="consentimento_oracao">
                                                    <input id="consentimento_oracao" type="checkbox"
                                                        name="autorizadoCompartilhar" />
                                                    Autorizo que meu pedido (sem dados sensíveis) seja compartilhado com
                                                    o círculo
                                                    de intercessão da igreja.
                                                </label>

                                                <button type="submit" class="btn">
                                                    <i class="far fa-paper-plane" aria-hidden="true"></i>
                                                    Enviar pedido
                                                </button>
                                            </form>
                                        </div>

                                        <div class="card">
                                            <h3>Pedido de oração por WhatsApp</h3>
                                            <p>Se preferir, envie seu pedido diretamente pelo WhatsApp:</p>
                                            <p>
                                                <a href="<%= contato.whatsapp %>?text=Gra%C3%A7a%20e%20paz!%20Quero%20fazer%20um%20pedido%20de%20ora%C3%A7%C3%A3o."
                                                    target="_blank" rel="noopener" class="btn">
                                                    <i class="fab fa-whatsapp" aria-hidden="true"></i>
                                                    Enviar pelo WhatsApp
                                                </a>
                                            </p>
                                        </div>
                                    </div>
                                </section>

                                <section id="contato">
                                    <h2>Contato</h2>
                                    <p class="section-subtitle">
                                        Fale com a Igreja da Vitória.
                                    </p>

                                    <div class="contact-wrapper">
                                        <div class="card">
                                            <form action="/contato" method="POST" novalidate>
                                                <label for="nome">Nome</label>
                                                <input id="nome" name="nome" type="text" placeholder="Seu nome completo"
                                                    required aria-required="true" />

                                                <label for="email">E-mail</label>
                                                <input id="email" name="email" type="email"
                                                    placeholder="seuemail@exemplo.com" required aria-required="true" />

                                                <label for="mensagem">Mensagem</label>
                                                <textarea id="mensagem" name="mensagem"
                                                    placeholder="Escreva sua mensagem" required
                                                    aria-required="true"></textarea>

                                                <button type="submit" class="btn">
                                                    <i class="far fa-paper-plane" aria-hidden="true"></i>
                                                    Enviar mensagem
                                                </button>
                                            </form>
                                        </div>

                                        <div class="card">
                                            <h3>Informações</h3>
                                            <p><strong>Cidade:</strong>
                                                <%= contato.cidade %>
                                            </p>
                                            <p><strong>Bairro:</strong>
                                                <%= contato.bairro %>
                                            </p>
                                            <p><strong>Endereço:</strong>
                                                <%= contato.endereco %>
                                            </p>
                                            <br />
                                            <p><strong>Instagram da igreja:</strong> <a
                                                    href="<%= contato.instagramIgreja %>" target="_blank"
                                                    rel="noopener">@igvitoria.jaragua</a></p>
                                            <p><strong>Instagram do Pr. Presidente:</strong> <a
                                                    href="<%= contato.instagramPastor %>" target="_blank"
                                                    rel="noopener">@prdaniel10</a></p>

                                            <div class="map-wrapper">
                                                <h3>Como chegar</h3>
                                                <p>Clique no mapa para traçar a rota até a igreja.</p>
                                                <iframe
                                                    src="https://www.google.com/maps?q=Setor%20Aeroporto%2C%2013%20-%20Rua%20Jos%C3%A9%20M.%20Francisco%2C%20Jaragu%C3%A1%20-%20GO&output=embed"
                                                    width="100%" height="220" class="map-embed" loading="lazy"
                                                    referrerpolicy="no-referrer-when-downgrade"
                                                    title="Mapa para Igreja da Vitória">
                                                </iframe>
                                            </div>
                                        </div>
                                    </div>
                                </section>
            </main>

            <div class="floating-social" aria-label="Acesso rápido redes sociais">
                <a class="whatsapp"
                    href="<%= contato.whatsapp %>?text=Gra%C3%A7a%20e%20paz!%20Quero%20uma%20informa%C3%A7%C3%A3o%20da%20Igreja%20da%20Vit%C3%B3ria."
                    target="_blank" rel="noopener" aria-label="WhatsApp">
                    <i class="fab fa-whatsapp" aria-hidden="true"></i>
                </a>
                <a class="instagram" href="<%= contato.instagramIgreja %>" target="_blank" rel="noopener"
                    aria-label="Instagram">
                    <i class="fab fa-instagram" aria-hidden="true"></i>
                </a>
                <a class="youtube"
                    href="https://www.youtube.com/results?search_query=igreja+da+vit%C3%B3ria+jaragu%C3%A1+goi%C3%A1s"
                    target="_blank" rel="noopener" aria-label="YouTube">
                    <i class="fab fa-youtube" aria-hidden="true"></i>
                </a>
            </div>

            <%- include("../partials/footer") %>

                <script src="/js/main.js"></script>
    </body>

</html>