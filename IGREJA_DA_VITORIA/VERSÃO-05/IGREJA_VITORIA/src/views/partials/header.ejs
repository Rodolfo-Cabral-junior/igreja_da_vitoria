<header class="header-translucent">
    <div class="nav-container">
        <a class="logo" href="#inicio" aria-label="Ir para início"
            style="display: flex; align-items: center; gap: 8px;">
            <img src="/img/logotopo.png" alt="Logo Igreja da Vitória" style="height: 48px; width: auto;">
            <span class="logo-text">Igreja da Vitória</span>
        </a>
        <button class="menu-toggle" aria-label="Abrir menu" id="menuToggle">
            <span class="menu-icon"></span>
        </button>
        <nav aria-label="Navegação principal" class="main-nav" id="mainNav">
            <ul>
                <li><a href="#inicio">Início</a></li>
                <li><a href="#sobre">Sobre</a></li>
                <li><a href="#cultos">Cultos</a></li>
                <li><a href="#calendario">Eventos</a></li>
                <li><a href="#ministerios">Ministérios</a></li>
                <li><a href="#doacoes">Doações</a></li>
                <li><a href="#oracao">Oração</a></li>
                <li><a href="#contato">Contato</a></li>
            </ul>
        </nav>
        <div class="social-bar" aria-label="Redes sociais">
            <a class="social-btn" href="https://www.instagram.com/igvitoria.jaragua/?hl=en" target="_blank"
                rel="noopener" aria-label="Instagram da Igreja da Vitória">
                <i class="fab fa-instagram" aria-hidden="true"></i>
                <span>Instagram</span>
            </a>
            <a class="social-btn"
                href="https://www.youtube.com/results?search_query=igreja+da+vit%C3%B3ria+jaragu%C3%A1+goi%C3%A1s"
                target="_blank" rel="noopener" aria-label="Canal da Igreja da Vitória no YouTube">
                <i class="fab fa-youtube" aria-hidden="true"></i>
                <span>YouTube</span>
            </a>
        </div>
    </div>
</header>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var menuToggle = document.getElementById('menuToggle');
        var mainNav = document.getElementById('mainNav');
        menuToggle.addEventListener('click', function (e) {
            e.stopPropagation();
            document.body.classList.toggle('menu-open');
        });
        document.addEventListener('click', function (e) {
            if (document.body.classList.contains('menu-open')) {
                if (!mainNav.contains(e.target) && e.target !== menuToggle) {
                    document.body.classList.remove('menu-open');
                }
            }
        });
        window.addEventListener('resize', function () {
            if (window.innerWidth > 1024) document.body.classList.remove('menu-open');
        });
        Array.from(mainNav.querySelectorAll('ul li a')).forEach(function (link) {
            link.addEventListener('click', function () {
                document.body.classList.remove('menu-open');
            });
        });
    });
</script>